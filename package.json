{
  "name": "anaemia",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "description": "a high-performance SolidJS SSR framework built for large projects",
  "scripts": {
    "build": "pnpm --filter @anaemia/* --filter !@anaemia/template-base build",
    "typecheck": "tsc --noEmit",
    "test": "pnpm -r --if-present test && pnpm -r --if-present test:integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "pnpm -r exec rm -rf dist .rspack node_modules",
    "check:unused": "knip",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js --patch",
    "release:dry": "node scripts/release.js --dry-run",
    "release:patch:dry": "node scripts/release.js --patch --dry-run"
  },
  "keywords": [
    "ssr",
    "rspack",
    "solidjs"
  ],
  "author": "colourlabs",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "@rspack/core": "^2.0.5",
      "@rspack/binding": "^2.0.5",
      "@rspack/dev-server": "^2.0.2",
      "@anaemia/core": "workspace:*",
      "@anaemia/cli": "workspace:*"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher"
    ]
  }
}
