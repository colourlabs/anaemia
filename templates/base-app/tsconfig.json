{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "exclude": ["src/__anaemia_entry__.tsx"],
  "include": ["src/**/*"]
}